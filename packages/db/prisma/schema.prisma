generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RiotAccount {
  id        String   @id @default(cuid())
  puuid     String   @unique
  gameName  String
  tagLine   String
  region    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MatchParticipant[]
}

enum MatchIngestStatus {
  PENDING
  INGESTED
  FAILED
}

model Match {
  id          String            @id // Riot matchId (e.g. NA1_123...)
  status      MatchIngestStatus @default(PENDING)
  firstSeenAt DateTime          @default(now())
  ingestedAt  DateTime?
  lastError   String?

  // Make these optional so we can insert rows before ingesting full details
  queueId     Int?
  gameStartAt DateTime?
  durationSec Int?
  patch       String?
  raw         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants MatchParticipant[]
}

model MatchParticipant {
  id         String  @id @default(cuid())
  matchId    String
  riotAccId  String

  championId Int
  teamId     Int
  win        Boolean

  kills      Int
  deaths     Int
  assists    Int

  lane       String?
  role       String?

  match      Match       @relation(fields: [matchId], references: [id])
  riotAcc    RiotAccount @relation(fields: [riotAccId], references: [id])

  @@unique([matchId, riotAccId])
  @@index([riotAccId])
  @@index([matchId])
  @@index([matchId, riotAccId])
  @@index([matchId, riotAccId, win])
  @@index([matchId, championId])
}
